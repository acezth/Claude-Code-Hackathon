# ------- Beat — environment variables -------
# Copy this file to `.env.local` and fill in your keys.
# Variables prefixed with VITE_ are exposed to the browser via import.meta.env.

# Google (Calendar, Gmail, Maps) -----------------------------------
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# Enable: Calendar API, Gmail API, Places API, Maps JavaScript API.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_MAPS_KEY=

# Strava ----------------------------------------------------------
# Create an app at https://www.strava.com/settings/api
VITE_STRAVA_CLIENT_ID=
# DO NOT expose the secret to the browser in production.
# For hackathon/dev you can drop it here, but move it to a server ASAP.
VITE_STRAVA_CLIENT_SECRET=
# Optional direct-token bootstrap for local hackathon demos.
# This lets the app work immediately even before OAuth connect is fully wired.
VITE_STRAVA_ACCESS_TOKEN=
VITE_STRAVA_REFRESH_TOKEN=
# Optional unix timestamp in seconds. Leave blank if unknown.
VITE_STRAVA_TOKEN_EXPIRES_AT=

# OpenAI ----------------------------------------------------------
# DO NOT expose in production. Use a server proxy. For hackathon it's OK.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
